{% liquid
  assign bg_image = section.settings.bg_image
%}

<section
  class="animated-text"
  style="
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    --glow-color: {{ section.settings.glow_color }};
    --font-size: {{ section.settings.font_size }}px;
    --radius: {{ section.settings.border_radius }}px;
    --speed: {{ section.settings.animation_speed }}s;
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>

  <div class="animated-text__overlay"></div>

  <div class="animated-text__logo">

    <h1>{{ section.settings.heading }}</h1>

    <svg viewBox="0 0 700 220" preserveAspectRatio="none">

      <defs>

        <linearGradient id="gradient-{{ section.id }}">
          <stop offset="0%" stop-color="#ffffff"/>
          <stop offset="50%" stop-color="{{ section.settings.glow_color }}"/>
          <stop offset="100%" stop-color="#ffffff"/>
        </linearGradient>

        <filter id="glow-{{ section.id }}">
          <feGaussianBlur stdDeviation="4" result="blur"/>
          <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>

      </defs>

      <rect
        class="frame"
        x="15"
        y="15"
        rx="{{ section.settings.border_radius }}"
        ry="{{ section.settings.border_radius }}"
        width="670"
        height="190"/>

      <rect
        class="light"
        x="15"
        y="15"
        rx="{{ section.settings.border_radius }}"
        ry="{{ section.settings.border_radius }}"
        width="670"
        height="190"/>

    </svg>

  </div>

</section>

<style>

.animated-text{
    position:relative;
    display:flex;
    justify-content:center;
    align-items:center;
    width:100%;
    min-height:500px;
    padding:100px 20px;
    overflow:hidden;
    background-color:var(--bg-color);

    {% if bg_image != blank %}
    background-image:url('{{ bg_image | image_url: width: 2200 }}');
    background-size:cover;
    background-position:center;
    background-repeat:no-repeat;
    {% endif %}
}

.animated-text__overlay{
    position:absolute;
    inset:0;
    background:rgba(0,0,0,var(--overlay-opacity));
    z-index:1;
}

.animated-text__logo{
    position:relative;
    width:min(700px,100%);
    height:220px;
    z-index:2;
}

.animated-text h1{
    position:absolute;
    inset:0;
    display:flex;
    justify-content:center;
    align-items:center;
    margin:0;
    color:var(--text-color);
    font-size:var(--font-size);
    font-weight:700;
    letter-spacing:.15em;
    text-transform:lowercase;
    z-index:2;
}

.animated-text svg{
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
    overflow:visible;
}

.animated-text .frame{
    fill:none;
    stroke:rgba(255,255,255,.15);
    stroke-width:1.5;
}

.animated-text .light{
    fill:none;
    stroke:url(#gradient-{{ section.id }});
    stroke-width:3;
    stroke-linecap:round;
    stroke-dasharray:180 1200;
    stroke-dashoffset:0;
    animation:borderMove var(--speed) linear infinite;
    filter:url(#glow-{{ section.id }});
}

@keyframes borderMove{
    from{
        stroke-dashoffset:0;
    }
    to{
        stroke-dashoffset:-1380;
    }
}

@media screen and (max-width:990px){

    .animated-text{
        min-height:420px;
        padding:80px 21px;
    }

    .animated-text__logo{
        height:180px;
    }

    .animated-text h1{
        font-size:calc(var(--font-size) * .7);
    }

}

@media screen and (max-width:749px){

    .animated-text{
        min-height:340px;
        padding:60px 15px;
    }

    .animated-text__logo{
        height:130px;
    }

    .animated-text h1{
        font-size:calc(var(--font-size) * .45);
        letter-spacing:.08em;
    }

}

</style>

{% schema %}
{
  "name": "Animated Text",
  "tag": "section",
  "class": "animated-text",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "thezonoa"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a1915"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 45
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow Color",
      "default": "#6ef7ff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font Size",
      "min": 40,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 110
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation Speed",
      "min": 1,
      "max": 10,
      "step": 0.5,
      "unit": "sec",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Animated Text"
    }
  ]
}
{% endschema %}